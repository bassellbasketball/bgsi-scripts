-- AUTO APPLY SETTINGS ON STARTUP
-- Remote: "toggle setting" FireServer({ settingName })
-- Settings default=2 means Off by default, default=1 means On
-- We read save.Settings[name] and only toggle if wrong value
-- 1 = On (index 1 of options {"On","Off"}), 2 = Off
-- ══════════════════════════════════════════════════════════

task.spawn(function()
    local Network = RS:WaitForChild("Network", 15); if not Network then return end
    local toggleSetting = Network:WaitForChild("toggle setting", 15)
    if not toggleSetting then return end

    task.wait(3) -- wait for framework and save to load

    local function fw2()
        local ok, f = pcall(require, RS:WaitForChild("Framework", 5))
        return ok and f or nil
    end

    -- Wait for framework
    local f = nil
    for _ = 1, 30 do
        f = fw2()
        if f and f.Loaded then break end
        task.wait(0.5)
    end

    -- Desired states: settingName = desired value (1=On, 2=Off)
    local DESIRED = {
        HideOtherPets      = 1,  -- On  (screenshot)
        HideMyPets         = 1,  -- On
        SkipLegendaryHatch = 1,  -- On
        PotatoMode         = 1,  -- On
        HeightMeter        = 1,  -- On
        BubbleLock         = 2,  -- Off
        BubbleFX           = 2,  -- Off
        RebirthFX          = 2,  -- Off
        ShowBubbles        = 2,  -- Off
        BubbleGravity      = 2,  -- Off
        ShowFPS            = 2,  -- Off
        ItemNotifications  = 2,  -- Off
        ChatTips           = 2,  -- Off
    }

    local save = f and f.Save and f.Save.Get and f.Save.Get()
    local settings = save and save.Settings or {}

    for settingName, desired in pairs(DESIRED) do
        local current = tonumber(settings[settingName]) or 1
        if current ~= desired then
            pcall(function() toggleSetting:FireServer({ settingName }) end)
            task.wait(0.2)
        end
    end
    print("[Settings] Auto-applied startup settings")
end)

