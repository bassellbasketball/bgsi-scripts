local function getChestTimerText(chestName)
    local map   = workspace:FindFirstChild("Map"); if not map then return nil end
    local acts  = map:FindFirstChild("Activations"); if not acts then return nil end
    local chest = acts:FindFirstChild(chestName); if not chest then return nil end
    local gui   = chest:FindFirstChild("ChestTimer"); if not gui then return nil end
    local title = gui:FindFirstChild("Title"); if not title then return nil end
    return title.Text
end

local function isChestReady(chestName)
    local txt = getChestTimerText(chestName)
    if not txt or txt == "" then return true end
    return not (txt:match("%d+:%d+") or txt:match("%d+ Day"))
end

local function tryCollectChest(chestName)
    if not isChestReady(chestName) then return false end

    local char = lp.Character; if not char then return false end
    local map  = workspace:FindFirstChild("Map"); if not map then return false end
    local acts = map:FindFirstChild("Activations"); if not acts then return false end
    local chest = acts:FindFirstChild(chestName); if not chest then return false end

    -- Teleport to chest
    char:PivotTo(chest:GetPivot())
    task.wait(0.5)

    -- Confirmed Cobalt: "collect chest" FireServer({ chestName })
    local collectRemote = RS.Network:FindFirstChild("collect chest")
    if collectRemote then
        pcall(function() collectRemote:FireServer({ chestName }) end)
    end

    -- VFX: firesignal OnClientEvent { chestName, {} }
    local vfxRemote = RS.Network:FindFirstChild("chest collected")
    if vfxRemote then
        pcall(function() firesignal(vfxRemote.OnClientEvent, { chestName, {} }) end)
    end

    task.wait(0.5)

    -- Verify via timer
    local timerAfter = getChestTimerText(chestName)
    local collected  = timerAfter and (timerAfter:match("%d+:%d+") or timerAfter:match("%d+ Day"))
    if collected then
        notify("Chests", "✓ " .. chestName .. " | " .. tostring(timerAfter))
        return true
    else
        return false
    end
end

