local API_URL = "https://api.github.com/repos/" .. GITHUB_USER .. "/" .. GITHUB_REPO .. "/contents/" .. GITHUB_FILE

local function readFlags()
    local config = {}
    if not Rayfield.Flags then return config end
    for flagName, flagObj in pairs(Rayfield.Flags) do
        pcall(function()
            local val = flagObj.CurrentValue
            if val ~= nil then config[flagName] = val end
        end)
    end
    return config
end

local function applyFlags(config)
    if not Rayfield.Flags then return 0 end
    local loaded = 0
    for flagName, value in pairs(config) do
        local flagObj = Rayfield.Flags[flagName]
        if flagObj then
            pcall(function() flagObj:Set(value) end)
            loaded = loaded + 1
        end
    end
    return loaded
end

local function toBase64(data)
    local b64chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    local result = {}
    local padding = (3 - #data % 3) % 3
    data = data .. string.rep("\0", padding)
    for i = 1, #data, 3 do
        local a, b, c = data:byte(i, i+2)
        local n = a * 65536 + b * 256 + c
        table.insert(result, b64chars:sub(math.floor(n/262144)%64+1, math.floor(n/262144)%64+1))
        table.insert(result, b64chars:sub(math.floor(n/4096)%64+1,   math.floor(n/4096)%64+1))
        table.insert(result, b64chars:sub(math.floor(n/64)%64+1,     math.floor(n/64)%64+1))
        table.insert(result, b64chars:sub(n%64+1,                    n%64+1))
    end
    local out = table.concat(result)
    return out:sub(1, #out - padding) .. string.rep("=", padding)
end

-- Fetch settings from GitHub and apply to all flags
local function loadFromGitHub()
    local ok, data = pcall(function()
        return game:HttpGet(RAW_URL .. "?t=" .. tostring(os.time()))
    end)
    if not ok or not data or data == "" or data:find("404") then
        return false, "No settings on GitHub yet -- push your settings first."
    end
    local config
    local parseOk = pcall(function() config = HS:JSONDecode(data) end)
    if not parseOk or not config then
        return false, "Failed to parse settings from GitHub."
    end
    local loaded = applyFlags(config)
    return true, loaded
end

-- Push current settings up to GitHub
local function pushToGitHub()
    if GITHUB_TOKEN == "YOUR_GITHUB_TOKEN_HERE" or GITHUB_TOKEN == "" then
        return false, "No token set -- paste your GitHub token into the script first."
    end

    local config  = readFlags()
    local encoded = HS:JSONEncode(config)

    -- Get current file SHA (required by GitHub API to update an existing file)
    local sha = nil
    pcall(function()
        local info = HS:RequestAsync({
            Url     = API_URL,
            Method  = "GET",
            Headers = {
                ["Authorization"] = "token " .. GITHUB_TOKEN,
                ["User-Agent"]    = "YESHub",
            }
        })
        if info and info.StatusCode == 200 then
            local parsed = HS:JSONDecode(info.Body)
            sha = parsed and parsed.sha
        end
    end)

    local bodyTable = {
        message = "Update settings from YESHub",
        content = toBase64(encoded),
    }
    if sha then bodyTable.sha = sha end

    local ok2, res = pcall(function()
        return HS:RequestAsync({
            Url     = API_URL,
            Method  = "PUT",
            Headers = {
                ["Authorization"] = "token " .. GITHUB_TOKEN,
                ["Content-Type"]  = "application/json",
                ["User-Agent"]    = "YESHub",
            },
            Body = HS:JSONEncode(bodyTable),
        })
    end)

    if not ok2 or not res then
        return false, "Request failed -- check executor allows HttpRequest."
    end
    if res.StatusCode == 200 or res.StatusCode == 201 then
        return true, "Pushed! All accounts sync these settings on next inject."
    else
        return false, "GitHub error " .. tostring(res.StatusCode)
    end
end

