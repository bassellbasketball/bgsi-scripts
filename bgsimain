local function buildItemList()
    local db = getDB(); if not db then return {} end
    local names, seen = {}, {}
    if db.Items then
        for name, data in pairs(db.Items) do
            if type(data)=="table"
               and not data.crafting  and not data.special
               and not data.flag      and not data.droppable
               and not data.petCube   and not data.tradable
               and (USABLE_CATS[data.category or ""]
                    or data.duration  or data.fruit or data.Treat) then
                if not seen[name] then table.insert(names, name); seen[name]=true end
            end
        end
    end
    if db.Potions then
        for name, _ in pairs(db.Potions) do
            if not seen[name] then table.insert(names, name); seen[name]=true end
        end
    end
    table.sort(names)
    return names
end

