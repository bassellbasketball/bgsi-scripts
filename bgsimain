local RebirthTab = Window:CreateTab("Auto Rebirth", 4483362458)

local function getRebirthCost(cur, amt)
    local function sc(n) local s = n*(n+1)/2; return s*s end
    return 100 * (sc(cur+amt) - sc(cur))
end

local function getMaxAffordable(cur, bubbles)
    if getRebirthCost(cur, 1) > bubbles then return 0 end
    local lo, hi = 1, 1
    while getRebirthCost(cur, hi) <= bubbles do hi = hi * 2 end
    while lo < hi do
        local mid = math.floor((lo+hi+1)/2)
        if getRebirthCost(cur, mid) <= bubbles then lo = mid else hi = mid-1 end
    end
    return lo
end

