    "Extra Lucky I",   -- Extra Lucky I
    "More Storage III",-- More Storage III
    "Extra Lucky II",  -- Extra Lucky II
    "Extra Lucky III", -- Extra Lucky III
}

local EGGS_TREE_KNOTS = {
    "Double Hatch Chance",
    "Lucky Common Eggs",
    "Lucky Rare Eggs",
    "Lucky Epic Eggs",
    "Faster Hatch I",
    "Faster Hatch II",
    "Faster Hatch III",
    "Egg Slots I",
    "Egg Slots II",
    "Egg Slots III",
    "Pity Boost I",
    "Pity Boost II",
    "Offline Cost Reducer",
    "Offline Hatch Speed I",
    "Offline Hatch Speed II",
    "More Jumps II",
    "More Jumps III",
    "Shiny Egg Boost I",
    "Shiny Egg Boost II",
    "Egg Apprentice",
    "Egg Master",
}

local buyKnotRemote = nil
task.spawn(function()
    buyKnotRemote = RS:WaitForChild("Network"):WaitForChild("buy skill tree knot", 30)
end)

-- Track owned knots locally — reset on toggle
-- Server returns { true } = bought, { false } = owned OR can't afford
-- We distinguish by checking token balance before attempting
local ownedKnots = {}

local function getRebirthTokens()
    local save = getSave(); if not save then return 0 end
    return tonumber(save.RebirthTokens or save.rebirthTokens or 0) or 0
end

local function getKnotPrice(knotName)
    local db = getDB(); if not db or not db.SkillTree then return math.huge end
    local data = db.SkillTree[knotName]
    if not data then return math.huge end
    return tonumber(data.price or 0) or 0
end

-- Returns: "owned", "bought", "cantafford", "failed"
local function tryBuyKnot(knotName)
    if ownedKnots[knotName] then return "owned" end
    if not buyKnotRemote then return "failed" end

    local tokens = getRebirthTokens()
    local price  = getKnotPrice(knotName)

    -- If price is math.huge, DB doesn't have this knot — try anyway
    -- If price known and can't afford, skip
    if price ~= math.huge and price > 0 and tokens < price then
        return "cantafford"
    end

    local ok, result = pcall(function()
        return buyKnotRemote:InvokeServer({ knotName })
    end)

    if ok and type(result) == "table" and result[1] == true then
        ownedKnots[knotName] = true
        notify("Skill Tree", "✓ " .. knotName)
        print("[SkillTree] Bought: " .. knotName)
        return "bought"
    end

    -- Server returned false:
    -- If we had enough tokens (or free), it means already owned
    -- If we didn't have tokens, it means can't afford
    if price == 0 or price == math.huge or tokens >= price then
        ownedKnots[knotName] = true -- mark owned so we don't retry
        return "owned"
    end

    return "cantafford"
end

-- Returns true = all done, false = stopped (can't afford), nil = retry after rebirth
local function doSkillTree()
    -- Phase 1: priority knots — skip unaffordable, buy what we can
    -- Do NOT stop on cantafford — a later knot may be cheaper
    local anyPriorityLeft = false
    for _, knotName in ipairs(SKILL_TREE_PRIORITY) do
        if not ownedKnots[knotName] then
            local result = tryBuyKnot(knotName)
            if result == "cantafford" then
                anyPriorityLeft = true -- still have unowned knots we can't afford yet
            elseif result == "bought" then
                task.wait(0.3)
            end
            -- "owned"/"failed" — continue to next
        end
    end
    if anyPriorityLeft then
        return false -- some priority knots still unaffordable, retry after rebirth
    end

    -- Phase 2: Eggs tree — buy any affordable, skip unaffordable
    local boughtAny = true
    while boughtAny do
        boughtAny = false
        local allOwned = true
        for _, knotName in ipairs(EGGS_TREE_KNOTS) do
            if not ownedKnots[knotName] then
                allOwned = false
                local result = tryBuyKnot(knotName)
                if result == "bought" then
                    boughtAny = true
                    task.wait(0.3)
                end
            end
        end
        if allOwned then return true end -- all done
    end

    return nil -- made a pass but nothing bought, retry after rebirth
end

