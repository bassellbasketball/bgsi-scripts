local function getGemPickups()
    local pickupsFolder = workspace:FindFirstChild("Visual")
        and workspace.Visual:FindFirstChild("Instances")
        and workspace.Visual.Instances:FindFirstChild("Pickups")
    if not pickupsFolder then return {} end

    local result = {}
    for _, pickup in ipairs(pickupsFolder:GetChildren()) do
        if not pickup.Parent then continue end
        if not isGemPickup(pickup) then continue end
        local pos = pickup:FindFirstChild("POS")
        if not pos then continue end
        if not pickup:GetAttribute("HasLanded") then continue end
        table.insert(result, { pickup = pickup, pos = pos })
    end
    return result
