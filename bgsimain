-- ══════════════════════════════════════════════════════════

-- All eggs confirmed from decompile with masteryLvl requirements
local ALL_EGGS_WITH_MASTERY = {
    { name = "Basic Egg",        masteryLvl = 0  },
    { name = "Galaxy Egg",       masteryLvl = 0  },
    { name = "Crystalite Egg",   masteryLvl = 0  },
    { name = "Spotted Egg",      masteryLvl = 2  },
    { name = "Spikey Egg",       masteryLvl = 4  },
    { name = "Arcane Egg",       masteryLvl = 6  },
    { name = "Frosted Egg",      masteryLvl = 9  },
    { name = "Cosmic Void Egg",  masteryLvl = 20 },
    { name = "Abstrax Egg",      masteryLvl = 30 },
    { name = "Release Egg",      masteryLvl = 0  },
    { name = "Twilight Egg",     masteryLvl = 0  },
    { name = "Phoenix Egg",      masteryLvl = 0  },
    { name = "Crystal Egg",      masteryLvl = 0  },
    { name = "Surprise Egg",     masteryLvl = 0  },
}

local eggUnlockViewedRemote = nil
task.spawn(function()
    eggUnlockViewedRemote = RS:WaitForChild("Network"):WaitForChild("egg unlock viewed", 30)
end)

local viewedEggs = {} -- track which eggs we've already viewed this session

local function getPlayerMasteryLevel()
    local ok, f = pcall(require, RS:WaitForChild("Framework", 5))
    if not ok or not f then return 0 end
    local save = f.Save and f.Save.Get and f.Save.Get()
    if not save then return 0 end
    local mastery = save.Mastery and save.Mastery.Eggs or 0
    -- Convert mastery XP to level using framework
    if f.Shared and f.Shared.MasteryXPToLevel then
        return f.Shared.MasteryXPToLevel(mastery) or 0
    end
    return 0
end

local function viewUnlockedEggs()
    if not eggUnlockViewedRemote then return end
    local masteryLevel = getPlayerMasteryLevel()
    local newlyViewed  = 0

    for _, egg in ipairs(ALL_EGGS_WITH_MASTERY) do
        if masteryLevel >= egg.masteryLvl and not viewedEggs[egg.name] then
            pcall(function() eggUnlockViewedRemote:FireServer({ egg.name }) end)
            viewedEggs[egg.name] = true
            newlyViewed = newlyViewed + 1
            task.wait(0.2)
        end
    end

    return newlyViewed
end

local function hasUnviewedMasteryEggs()
    local masteryLevel = getPlayerMasteryLevel()
    for _, egg in ipairs(ALL_EGGS_WITH_MASTERY) do
        if egg.masteryLvl > 0 and masteryLevel >= egg.masteryLvl and not viewedEggs[egg.name] then
            return true
        end
    end
    return false
end

-- Fire on startup for all eggs immediately
task.spawn(function()
    task.wait(3)
    viewUnlockedEggs()
    print("[Egg Unlock] Viewed all currently unlocked eggs")

    -- Then check every 5 minutes ONLY if there are unviewed mastery eggs
    while true do
        task.wait(300)
        if hasUnviewedMasteryEggs() then
            local n = viewUnlockedEggs()
            if n > 0 then
                print("[Egg Unlock] Viewed " .. n .. " newly unlocked egg(s)")
            end
        end
    end
end)

