-- Teleports to each chest, collects, then returns to egg stand if hatching
-- Timer read from workspace.Map.Activations[name].ChestTimer.Title.Text

-- Exact chest teleport positions provided by user
-- Using these instead of GetPivot() to avoid teleporting inside the chest
local CHEST_POSITIONS = {
    ["Sky Chest"]    = Vector3.new(-2182.23, 1608.85,  -498.97),
    ["Frosty Chest"] = Vector3.new(-2200.81, 11695.73, -557.64),
    ["Lunar Chest"]  = Vector3.new(-2133.80, 19588.48, -483.59),
    ["Void Chest"]   = Vector3.new(-2184.67, 28797.41, -565.96),
    ["Daily Chest"]  = Vector3.new(-2085.84, 139.79,   -127.42),
}

local ALL_CHESTS = {
    "Sky Chest",
    "Frosty Chest",
    "Lunar Chest",
    "Void Chest",
    "Daily Chest",
}

local function getChestTimerText(chestName)
    local map   = workspace:FindFirstChild("Map"); if not map then return nil end
    local acts  = map:FindFirstChild("Activations"); if not acts then return nil end
    local chest = acts:FindFirstChild(chestName); if not chest then return nil end
    local gui   = chest:FindFirstChild("ChestTimer"); if not gui then return nil end
    local title = gui:FindFirstChild("Title"); if not title then return nil end
    return title.Text
end

local function isChestReady(chestName)
    local txt = getChestTimerText(chestName)
    if not txt or txt == "" then return true end
    return not (txt:match("%d+:%d+") or txt:match("%d+ Day"))
end

local function tryCollectChest(chestName)
    if not isChestReady(chestName) then return false end

    local char = lp.Character; if not char then return false end

    -- Teleport to exact coords to avoid bugging inside chest
    local pos = CHEST_POSITIONS[chestName]
    if pos then
        char:PivotTo(CFrame.new(pos))
    else
        -- Fallback: use workspace activation position
        local map  = workspace:FindFirstChild("Map"); if not map then return false end
        local acts = map:FindFirstChild("Activations"); if not acts then return false end
        local chest = acts:FindFirstChild(chestName); if not chest then return false end
        char:PivotTo(chest:GetPivot() * CFrame.new(0, 3, 5))
    end

    task.wait(1) -- settle before firing

    -- Confirmed Cobalt: "collect chest" FireServer({ chestName })
    local collectRemote = RS.Network:FindFirstChild("collect chest")
    if collectRemote then
        pcall(function() collectRemote:FireServer({ chestName }) end)
    end

    -- VFX
    local vfxRemote = RS.Network:FindFirstChild("chest collected")
    if vfxRemote then
        pcall(function() firesignal(vfxRemote.OnClientEvent, { chestName, {} }) end)
    end

    task.wait(0.5)

    -- Verify via timer
    local timerAfter = getChestTimerText(chestName)
    local collected  = timerAfter and (timerAfter:match("%d+:%d+") or timerAfter:match("%d+ Day"))
    if collected then
        notify("Chests", "✓ " .. chestName .. " | " .. tostring(timerAfter))
        return true
    else
        return false
    end
end

local chestFailedRetry = {}

WorldTab:CreateToggle({
    Name = "Auto Collect Chests",
    CurrentValue = false,
    Flag = "AutoChests",
    Callback = function(state)
        if state then
            chestFailedRetry = {}
            startThread("chests", function()
                while true do
                    for _, chestName in ipairs(ALL_CHESTS) do
                        pcall(function()
                            local result = tryCollectChest(chestName)
                            if result then
                                chestFailedRetry[chestName] = nil
                            else
                                local txt = getChestTimerText(chestName)
                                local onCooldown = txt and (txt:match("%d+:%d+") or txt:match("%d+ Day"))
                                if not onCooldown then
                                    chestFailedRetry[chestName] = true
                                end
                            end
                        end)
                        task.wait(5) -- 5s cooldown between each chest teleport
                    end

                    -- Retry failed ones
                    for chestName, _ in pairs(chestFailedRetry) do
                        pcall(function()
                            local result = tryCollectChest(chestName)
                            if result then chestFailedRetry[chestName] = nil end
                        end)
                        task.wait(5)
                    end

                    -- Return to egg stand if hatching
                    if Threads["hatch"] and cachedEggPos then
                        local char = lp.Character
                        if char then
                            char:PivotTo(CFrame.new(cachedEggPos + Vector3.new(0, 3, 4)))
                            notify("Chests", "Done — returned to egg stand")
                        end
                    end

                    task.wait(10)
                end
            end)
            notify("Chests", "Started — 5s between each chest")
        else
            stopThread("chests")
            notify("Chests", "Stopped.")
        end
    end,
})
        end
    end,
