local function isGemPickup(pickup)
    for _, child in ipairs(pickup:GetChildren()) do
        if child.Name:lower():find("gem") then return true end
    end
    return false
end

local function isCoinPickup(pickup)
    for _, child in ipairs(pickup:GetChildren()) do
        if child.Name:lower():find("coin") then return true end
    end
    return false
end

local function getPickupsOfType(typeCheck)
    local pickupsFolder = workspace:FindFirstChild("Visual")
        and workspace.Visual:FindFirstChild("Instances")
        and workspace.Visual.Instances:FindFirstChild("Pickups")
    if not pickupsFolder then return {} end
    local result = {}
    for _, pickup in ipairs(pickupsFolder:GetChildren()) do
        if not pickup.Parent then continue end
        if skippedPickups[pickup.Name] then continue end -- never retry blacklisted
        if not typeCheck(pickup) then continue end
        local pos = pickup:FindFirstChild("POS")
        if not pos then continue end
        if not pickup:GetAttribute("HasLanded") then continue end
        table.insert(result, { pickup = pickup, pos = pos })
    end
    return result
end

local skippedPickups = {} -- IDs of pickups that timed out — never retry these

local function handlePickup(pickup, pos)
    local root = getRoot(); if not root then return end
    local id = pickup.Name
    root.CFrame = pos.CFrame + Vector3.new(0, 3, 0)
    task.wait(0.15)
    pcall(function() CollectPickup:FireServer(id, pos.Position) end)
    pcall(function() ClickPickup:FireServer({ id }) end)
    pcall(function() MagnetPickup:FireServer(id) end)
    -- 3 second timeout — skip if not collected in time
    local timeout = os.clock() + 3
    while pickup.Parent ~= nil and os.clock() < timeout do
        if DamagePickup then
            pcall(function() DamagePickup:FireServer(id, 34, false, 1) end)
        end
        pcall(function() ClickPickup:FireServer({ id }) end)
        pcall(function() CollectPickup:FireServer(id, pos.Position) end)
        task.wait(0.08)
    end
    -- If still not gone after 3s, blacklist it permanently this session
    if pickup.Parent ~= nil then
        skippedPickups[id] = true
        print("[Farm] Skipped pickup " .. id .. " — blacklisted")
    end
end

-- Sweep all zones for a given pickup type
-- Returns true if at least one pickup was found and handled
local function sweepAllZones(typeCheck, typeName)
    local anyFound = false
    for _, zone in ipairs(FARM_ZONES) do
        tp(zone.pos + Vector3.new(0, 3, 0))
        notify("Auto Farm", zone.name .. " — " .. typeName)
        task.wait(5) -- wait for zone to load
        -- Drain all of this type in zone
        while true do
            local pickups = getPickupsOfType(typeCheck)
            if #pickups == 0 then break end
            anyFound = true
            for _, entry in ipairs(pickups) do
                if entry.pickup and entry.pickup.Parent then
                    handlePickup(entry.pickup, entry.pos)
                end
            end
        end
    end
    return anyFound
end

local autoBreakToggleRef = nil

local function doFarmLoop()
    while true do
        -- Pass 1: all gems across all zones
        local foundGems  = sweepAllZones(isGemPickup,  "Gems")
        -- Pass 2: all coins across all zones (while coins are collected, gems respawn)
        local foundCoins = sweepAllZones(isCoinPickup, "Coins")
        -- If both passes found nothing — truly empty everywhere, stop
        if not foundGems and not foundCoins then
            notify("Auto Farm", "All zones empty — stopping.")
            print("[Farm] Nothing found in any zone — stopping")
            stopThread("breakables")
            pcall(function()
                if autoBreakToggleRef then autoBreakToggleRef:Set(false) end
            end)
            return
        end
        -- Otherwise loop — gems may have respawned during coin pass
    end
end

