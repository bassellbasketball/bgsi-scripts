local function startMagnet()
    if magnetConn then magnetConn:Disconnect(); magnetConn = nil end
    magnetConn = RunSvc.Heartbeat:Connect(function(dt)
        if not magnetEnabled then return end
        local root = getRoot(); if not root then return end
        local rootPos = root.Position
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and CURRENCY_PICKUP_NAMES[obj.Name:lower()] then
                local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    local dist = (part.Position - rootPos).Magnitude
                    if dist > 1 then
                        local dir    = (rootPos - part.Position).Unit
                        local move   = math.min(MAGNET_SPEED * dt, dist)
                        local newPos = part.Position + dir * move
                        pcall(function()
                            if obj.PrimaryPart then obj:PivotTo(CFrame.new(newPos))
                            else part.CFrame = CFrame.new(newPos) end
                        end)
                    end
                end
            end
        end
    end)
end

