local flagInterval     = 60

local function getFlagNames()
    local db = getDB()
    if not db or not db.Items then return FLAG_FALLBACK end
    local names = {}
    for name, data in pairs(db.Items) do
        if type(data)=="table" and data.flag==true then table.insert(names, name) end
    end
    table.sort(names)
    return #names > 0 and names or FLAG_FALLBACK
end

