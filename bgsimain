-- ══════════════════════════════════════════════════════════
-- AUTO DISMISS POPUP — always runs in background
-- Framework.GUI.Message.Gui IS PlayerGui.Message (the ScreenGui itself)
-- Ok button found recursively inside it
-- Uses GetPropertyChangedSignal for instant dismiss + polling backup
-- ══════════════════════════════════════════════════════════

task.spawn(function()
    local pg = lp:WaitForChild("PlayerGui")

    -- Wait for Message ScreenGui — no .Gui child, Message IS the ScreenGui
    local messageGui = pg:WaitForChild("Message", 30)
    if not messageGui then
        print("[AutoDismiss] Message ScreenGui not found — skipping")
        return
    end

    local function tryDismiss()
        pcall(function()
            if not messageGui.Enabled then return end
            -- Recursive search — Ok button may be nested at any depth
            local okBtn = messageGui:FindFirstChild("Ok", true)
            if okBtn and okBtn:IsA("GuiButton") and okBtn.Visible then
                okBtn:Activate()
            end
        end)
    end

    -- Instant dismiss via property signal — fires the frame popup becomes visible
    messageGui:GetPropertyChangedSignal("Enabled"):Connect(function()
        if messageGui.Enabled then
            tryDismiss()
        end
    end)

    -- Polling backup every 0.1s in case signal fires before button is visible
    while true do
        tryDismiss()
        task.wait(0.1)
    end
end)
