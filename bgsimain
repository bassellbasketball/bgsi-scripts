-- Ordered knots to buy first (user-specified priority)
-- Knot names confirmed: Cobalt used "Start Skill Tree" for Walk Speed I
-- The server accepts the v14 node names directly (from decompile lines 25314-25420)
-- Two fixes vs previous version:
--   1. Correct key names matching v14 array
--   2. Do NOT stop on cantafford in priority — skip and continue to buy
--      cheaper knots that are still affordable
local SKILL_TREE_PRIORITY = {
    "Walk Speed I",    -- Start Skill Tree (free)
    "More Jumps I",    -- Hatch Tempo I    (2 tokens)
    "Eggs Portal",     -- Eggs Upgrades    (price varies)
    "Walk Speed II",   -- Bubble Power I   (3 tokens)
