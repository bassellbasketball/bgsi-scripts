-- ── HATCH LOGIC ──────────────────────────────────────────

local hatchSetupDone = false
local cachedEggPos   = nil

local function isFlagExpired(slot, flagName)
    if flagName == "None" then return false end
    local elapsed = os.clock() - flagPlacedAt[slot]
    -- Re-place 10s early to avoid coverage gaps
    return elapsed >= (flagSlotInterval[slot] - 10)
end

local function placeFlag(slot, flagName, eggPos)
    if flagName == "None" then return end
    local offset = slot == 1 and Vector3.new(-6, 3, 0) or Vector3.new(6, 3, 0)
    tp(eggPos + offset); task.wait(0.2)
    useItem(flagName, 1); task.wait(0.2)
    flagPlacedAt[slot] = os.clock()
end

local function setupHatch()
    if not selectedEgg or selectedEgg == "(Retry — reopen dropdown)" then return end
    local f = fw(); if not f then return end

    local save = getSave()
    if save and save.Settings then save.Settings.SkipLegendaryHatch = 1 end

    local map        = f.WorldUtil and f.WorldUtil.GetMap and f.WorldUtil.GetMap(); if not map then return end
    local eggsFolder = map:FindFirstChild("Eggs"); if not eggsFolder then return end
    local eggModel   = eggsFolder:FindFirstChild(selectedEgg); if not eggModel then return end
    local primary    = eggModel.PrimaryPart; if not primary then return end

    cachedEggPos = primary.Position
    tp(cachedEggPos + Vector3.new(0, 3, 4)); task.wait(0.3)

    -- Place both flags on first setup
    placeFlag(1, hatchFlag1, cachedEggPos)
    placeFlag(2, hatchFlag2, cachedEggPos)

    -- Return to hatch position
    tp(cachedEggPos + Vector3.new(0, 3, 4)); task.wait(0.2)
    hatchSetupDone = true
end

local function doHatch()
    local f = fw(); if not f then return end
    if not hatchSetupDone then
        setupHatch(); if not hatchSetupDone then return end
    end

    -- Re-place expired flags without interrupting hatching
    if cachedEggPos then
        if isFlagExpired(1, hatchFlag1) then
            placeFlag(1, hatchFlag1, cachedEggPos)
            tp(cachedEggPos + Vector3.new(0, 3, 4)); task.wait(0.1)
        end
        if isFlagExpired(2, hatchFlag2) then
            placeFlag(2, hatchFlag2, cachedEggPos)
            tp(cachedEggPos + Vector3.new(0, 3, 4)); task.wait(0.1)
        end
    end

    if f.Variables then f.Variables.OpeningEgg = false end
    pressKey(Enum.KeyCode.T)
end

HatchTab:CreateToggle({
