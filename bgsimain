    Flag = "AutoHatch",
    Callback = function(state)
        if state then
            hatchSetupDone    = false
            cachedEggPos      = nil
            flagPlacedAt      = { [1] = 0, [2] = 0 }
            startThread("hatch", function()
                while true do pcall(doHatch); task.wait(0.1) end
            end)
            notify("Auto Hatch", "Teleporting once, flags placed, pressing T")
        else
