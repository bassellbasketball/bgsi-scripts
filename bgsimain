local SpinTab = Window:CreateTab("Auto Spin", 4483362458)

local spinConn     = nil
local spinBusy     = false

local function doSpin()
    if spinBusy then return end
    spinBusy = true

    local f = fw()
    if not f then spinBusy = false; return end

    -- Check we have spins available
    local save = getSave()
    local osTime = f.Network.Invoke("Get OSTime") or os.time()
    local spins  = save and (tonumber(save.PrizeWheelSpins) or 0) or 0
    local freeIn = save and save.PrizeWheelTime and (save.PrizeWheelTime - osTime) or 0
    if spins <= 0 and freeIn > 0 then
        spinBusy = false
        return
    end

    -- Invoke "Spin Prize Wheel" — RemoteFunction, framework wraps in CreatePacket
    local result = f.Network.Invoke("Spin Prize Wheel")

    if typeof(result) == "table" and result.success then
        -- Immediately fire "Prize Wheel Done" to skip the 4s animation
        pcall(function() f.Network.Fire("Prize Wheel Done") end)
    elseif typeof(result) == "table" and result.reason then
        -- No spins or already spinning — stop
        if result.reason == "No spins available" then
            stopThread("spin")
            notify("Auto Spin", "No spins remaining — stopped.")
        end
    end

    spinBusy = false
end

SpinTab:CreateToggle({
    Name = "Auto Spin Wheel",
    CurrentValue = false,
    Flag = "AutoSpin",
    Callback = function(state)
        if state then
            spinBusy = false
