-- CONFIG TAB — Named config saves with dropdown to load
-- Each config saved as: yeshub_config_<name>.json
-- ══════════════════════════════════════════════════════════

local ConfigTab   = Window:CreateTab("Config", 4483362458)
local HS          = game:GetService("HttpService")
local CONFIG_DIR  = "YESHub_Configs"
local selectedConfig = "default"

-- Ensure folder exists
pcall(function()
    if not isfolder(CONFIG_DIR) then
        makefolder(CONFIG_DIR)
    end
end)

local function getConfigPath(name)
    return CONFIG_DIR .. "/" .. name .. ".json"
end

local function listConfigs()
    local files = {}
    pcall(function()
        for _, f in ipairs(listfiles(CONFIG_DIR)) do
            -- Extract name from path, strip .json
            local name = f:match("([^/\\]+)%.json$")
            if name then table.insert(files, name) end
        end
    end)
    if #files == 0 then table.insert(files, "default") end
    table.sort(files)
    return files
end

local function readFlags()
    local config = {}
    if not Rayfield.Flags then return config end
    for flagName, flagObj in pairs(Rayfield.Flags) do
        pcall(function()
            local val = flagObj.CurrentValue
            if val ~= nil then config[flagName] = val end
        end)
    end
    return config
end

local function applyFlags(config)
    if not Rayfield.Flags then return 0 end
    local loaded = 0
    for flagName, value in pairs(config) do
        local flagObj = Rayfield.Flags[flagName]
        if flagObj then
            pcall(function() flagObj:Set(value) end)
            loaded = loaded + 1
        end
    end
    return loaded
end

-- Config name input via a simple text label + button approach
-- (Rayfield doesn't have text input, so we use a dropdown of existing + "default")
