}

local EGGS_TREE_KNOTS = {
    "Double Hatch Chance",
    "Lucky Common Eggs",
    "Lucky Rare Eggs",
    "Lucky Epic Eggs",
    "Faster Hatch I",
    "Faster Hatch II",
    "Faster Hatch III",
    "Egg Slots I",
